class CoachFrancais:

    def __init__(self):
        self.niveau_aide = 1

    def verifier(self, reponse_eleve, bonne_reponse):

        if reponse_eleve.lower() == bonne_reponse.lower():

            self.niveau_aide = 1

            return """
✅ Bravo !

Ta réponse est correcte.

🧠 Comment as-tu trouvé ?
"""

        else:

            if self.niveau_aide == 1:

                self.niveau_aide += 1

                return """
❌ Ce n'est pas la bonne réponse.

Observe bien le verbe.

Essaie encore.
"""

            elif self.niveau_aide == 2:

                self.niveau_aide += 1

                return """
💡 Indice :

Cherche quand se déroule l'action.

Hier ?
Aujourd'hui ?
Demain ?
"""

            elif self.niveau_aide == 3:

                self.niveau_aide += 1

                return """
🛠️ Stratégie :

Repère le verbe.

Puis demande-toi :

- passé
- présent
- futur
"""

            else:

                self.niveau_aide = 1

                return f"""
✅ Réponse attendue :

{bonne_reponse}

Retiens cette stratégie pour la prochaine fois.
"""
